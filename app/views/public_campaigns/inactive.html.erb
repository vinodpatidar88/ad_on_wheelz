<div class="container py-5 my-auto text-center">
  <div class="row justify-content-center">
    <div class="col-lg-5 col-md-7 col-sm-10">
      <div class="glass-card p-5 fade-in">
        <div class="mb-4">
          <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-danger" style="width: 70px; height: 70px; box-shadow: 0 0 25px rgba(239, 68, 68, 0.35);">
            <i class="fa-solid fa-circle-exclamation text-white" style="font-size: 30px;"></i>
          </span>
        </div>
        
        <h3 class="text-white fw-bold mb-3">Campaign Inactive</h3>
        <p class="text-muted mb-4">
          The campaign you scanned is currently inactive. This might be because the promotion period hasn't started yet, has already expired, or the campaign is temporarily offline.
        </p>

        <% if @campaign.present? %>
          <div class="p-3 bg-dark rounded-4 border border-secondary mb-4">
            <small class="text-muted d-block mb-1">Campaign Period</small>
            <span class="text-white fw-semibold">
              <%= @campaign.start_date.strftime("%b %d, %Y") %> – <%= @campaign.end_date.strftime("%b %d, %Y") %>
            </span>
          </div>
        <% end %>

        <a href="#" onclick="window.close(); return false;" class="btn btn-outline-light w-100">Close Window</a>
      </div>
    </div>
  </div>
</div>
