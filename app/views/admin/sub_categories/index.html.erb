<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom border-secondary">
  <h1 class="h2 text-white">Sub Categories</h1>
  <%= link_to 'New Sub Category', new_admin_sub_category_path, class: 'btn btn-primary' %>
</div>

<div class="admin-card">
  <div class="table-responsive">
    <table class="table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Category</th>
          <th>Name</th>
          <th>Description</th>
          <th style="width: 150px;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if @sub_categories.any? %>
          <% @sub_categories.each do |sub_category| %>
            <tr>
              <td><%= sub_category.id %></td>
              <td><span class="badge bg-secondary"><%= sub_category.category&.name %></span></td>
              <td class="fw-bold text-white"><%= sub_category.name %></td>
              <td><%= sub_category.description %></td>
              <td>
                <div class="d-flex gap-2">
                  <%= link_to 'Edit', edit_admin_sub_category_path(sub_category), class: 'btn btn-outline-warning btn-sm' %>
                  <%= button_to 'Delete', admin_sub_category_path(sub_category), method: :delete, data: { turbo_confirm: 'Are you sure?' }, class: 'btn btn-outline-danger btn-sm' %>
                </div>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="5" class="text-center text-muted py-4">No sub categories created yet.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
