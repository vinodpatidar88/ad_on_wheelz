<%= form_with(model: [:admin, campaign], local: true) do |f| %>
  <% if campaign.errors.any? %>
    <div class="alert alert-danger">
      <h6 class="alert-heading"><%= pluralize(campaign.errors.count, "error") %> prohibited this campaign from being saved:</h6>
      <ul class="mb-0">
        <% campaign.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :sub_category_id, "Sub Category", class: 'form-label text-white' %>
    <%= f.collection_select :sub_category_id, SubCategory.all, :id, :name, { prompt: "Select a Sub Category" }, class: 'form-select bg-dark text-white border-secondary' %>
  </div>

  <div class="mb-3">
    <%= f.label :name, class: 'form-label text-white' %>
    <%= f.text_field :name, class: 'form-control bg-dark text-white border-secondary' %>
  </div>

  <div class="mb-3">
    <%= f.label :description, class: 'form-label text-white' %>
    <%= f.text_area :description, rows: 4, class: 'form-control bg-dark text-white border-secondary' %>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :start_date, class: 'form-label text-white' %>
      <%= f.datetime_field :start_date, class: 'form-control bg-dark text-white border-secondary' %>
    </div>

    <div class="col-md-6 mb-3">
      <%= f.label :end_date, class: 'form-label text-white' %>
      <%= f.datetime_field :end_date, class: 'form-control bg-dark text-white border-secondary' %>
    </div>
  </div>

  <div class="mt-4">
    <%= f.submit class: 'btn btn-primary me-2' %>
    <%= link_to 'Cancel', admin_campaigns_path, class: 'btn btn-outline-light' %>
  </div>
<% end %>
