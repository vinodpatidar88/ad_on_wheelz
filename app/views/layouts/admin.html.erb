<!DOCTYPE html>
<html>
  <head>
    <title>AdOnWheels Admin Portal</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <style>
      body {
        font-family: 'Outfit', sans-serif;
        background-color: #0b0a12;
        color: #e2e8f0;
      }
      .sidebar {
        min-height: 100vh;
        background: linear-gradient(180deg, #13121f 0%, #0d0c15 100%);
        border-right: 1px solid rgba(255,255,255,0.05);
      }
      .sidebar .nav-link {
        color: #94a3b8;
        padding: 0.8rem 1.5rem;
        font-weight: 500;
        transition: all 0.2s ease;
      }
      .sidebar .nav-link:hover, .sidebar .nav-link.active {
        color: #a855f7;
        background: rgba(168, 85, 247, 0.05);
        border-left: 3px solid #a855f7;
      }
      .admin-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        padding: 1.5rem;
        backdrop-filter: blur(10px);
      }
      .btn-primary {
        background-color: #8b5cf6;
        border-color: #8b5cf6;
      }
      .btn-primary:hover {
        background-color: #7c3aed;
        border-color: #7c3aed;
      }
      .table {
        color: #e2e8f0 !important;
      }
      .table th {
        background-color: #13121f !important;
        border-bottom-color: rgba(255,255,255,0.1) !important;
        color: #94a3b8 !important;
      }
      .table td {
        background-color: transparent !important;
        border-bottom-color: rgba(255,255,255,0.05) !important;
      }
      .alert-notice {
        background-color: rgba(16, 185, 129, 0.1);
        border: 1px solid rgba(16, 185, 129, 0.2);
        color: #10b981;
      }
      .alert-alert {
        background-color: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.2);
        color: #ef4444;
      }
    </style>
  </head>
  <body>
    <div class="container-fluid">
      <div class="row">
        <!-- Sidebar -->
        <nav class="col-md-3 col-lg-2 sidebar d-md-block collapse p-0">
          <div class="position-sticky pt-4">
            <div class="px-4 mb-4">
              <h4 class="text-white fw-bold mb-0">AdOnWheels</h4>
              <small class="text-muted">Admin Console</small>
            </div>
            <ul class="nav flex-column">
              <li class="nav-item">
                <a class="nav-link <%= controller_name == 'dashboard' ? 'active' : '' %>" href="<%= admin_root_path %>">Dashboard</a>
              </li>
              <li class="nav-item">
                <a class="nav-link <%= controller_name == 'categories' ? 'active' : '' %>" href="<%= admin_categories_path %>">Categories</a>
              </li>
              <li class="nav-item">
                <a class="nav-link <%= controller_name == 'sub_categories' ? 'active' : '' %>" href="<%= admin_sub_categories_path %>">Sub Categories</a>
              </li>
              <li class="nav-item">
                <a class="nav-link <%= controller_name == 'campaigns' ? 'active' : '' %>" href="<%= admin_campaigns_path %>">Campaigns</a>
              </li>
              <li class="nav-item">
                <a class="nav-link <%= controller_name == 'rewards' ? 'active' : '' %>" href="<%= admin_rewards_path %>">Rewards</a>
              </li>
              <li class="nav-item">
                <a class="nav-link <%= controller_name == 'user_profiles' ? 'active' : '' %>" href="<%= admin_user_profiles_path %>">User Profiles</a>
              </li>
            </ul>
            <hr class="mx-3 my-4" style="border-color: rgba(255,255,255,0.1)">
            <div class="px-4 text-center">
              <%= button_to "Sign Out", destroy_admin_user_session_path, method: :delete, class: "btn btn-outline-danger btn-sm w-100" %>
            </div>
          </div>
        </nav>

        <!-- Main Content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
          <% if flash[:notice].present? %>
            <div class="alert alert-notice alert-dismissible fade show" role="alert">
              <%= flash[:notice] %>
            </div>
          <% end %>
          <% if flash[:alert].present? %>
            <div class="alert alert-alert alert-dismissible fade show" role="alert">
              <%= flash[:alert] %>
            </div>
          <% end %>

          <%= yield %>
        </main>
      </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
